REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_ACTIVE_SESSIONS=5
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15

# ── Super Admin ──────────────────────────────────────────────
SUPER_ADMIN_USER_NAME=admin
SUPER_ADMIN_PASSWORD_HASH=adminPass!123
