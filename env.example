# ── SMS — Arkesel ─────────────────────────────────────────────
SMS_PROVIDER=arkesel
ARKESEL_API_KEY=ekV0ZGp1YmFIQUViQkphR3JxaWY
ARKESEL_SENDER_ID=HepVac
ARKESEL_BASE_URL=https://sms.arkesel.com/sms/api

# ── Reminder Scheduler ───────────────────────────────────────
# How often the worker scans for due reminders (seconds)
REMINDER_SCAN_INTERVAL=300
# How many days ahead to look for due reminders
REMINDER_ADVANCE_DAYS=1
# Max SMS/email retry attempts before a reminder is marked failed
REMINDER_MAX_RETRIES=3

# ── Worker Tuning ────────────────────────────────────────────
# These are read directly by worker.py via os.getenv() — NOT via pydantic Settings.
# Uncomment and set only if you need to override the defaults.
# WORKER_CONCURRENCY=4
# WORKER_POLL_INTERVAL=1.0
# WORKER_RECLAIM_INTERVAL=60
# WORKER_CLAIM_BATCH=10
# WORKER_REMINDER_SCAN_INTERVAL=300
